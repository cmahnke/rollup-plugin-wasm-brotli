{
  "name": "@projektemacher/rollup-plugin-wasm-brotli",
  "version": "0.0.1",
  "description": "Locate and bundle WASM dependencies inline using brotli-unicode",
  "type": "module",
  "bin": {
    "compress": "./dist/compress.mjs"
  },
  "license": "MIT",
  "peerDependencies": {
    "rollup": "^2.78.0||^3.0.0||^4.0.0"
  },
  "peerDependenciesMeta": {
    "rollup": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "./dist/compress.mjs",
    "build": "rimraf dist/* && rollup -c",
    "test": "vitest",
    "clean": "rimraf dist/*",
    "lint": "tsc && eslint . -c eslint.config.mjs --report-unused-disable-directives --max-warnings 0",
    "knip": "knip",
    "jsdoc": "jsdoc -c jsdoc.config.json -r ."
  },
  "dependencies": {
    "brotli-unicode": "latest",
    "rollup": "^2.78.0||^3.0.0||^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.6.0",
    "better-docs": "^2.7.3",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "jsdoc": "^4.0.5",
    "knip": "^6.7.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "module": "./dist/es/index.js",
  "exports": {
    "types": "./types/index.d.ts",
    "import": "./dist/rollup-plugin-wasm-brotli.js"
  },
  "files": [
    "dist",
    "src",
    "types",
    "README.md"
  ],
  "keywords": [
    "rollup",
    "plugin",
    "wasm",
    "brotli"
  ],
  "bugs": {
    "url": "https://github.com/cmahnke/rollup-plugin-wasm-brotli/issues"
  },
  "homepage": "https://github.com/cmahnke/rollup-plugin-wasm-brotli#readme"
}
